#!/usr/bin/env python3
import argparse
import subprocess
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent


def main() -> int:
    ap = argparse.ArgumentParser(description="One orchestra tick: dispatch then reconcile.")
    ap.add_argument("--root", required=True)
    args = ap.parse_args()
    for tool in ("dispatch", "reconcile"):
        r = subprocess.run([sys.executable, str(HERE / tool), "--root", args.root],
                           capture_output=True, text=True)
        sys.stdout.write(r.stdout)
        sys.stderr.write(r.stderr)
        if r.returncode != 0:
            return r.returncode
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
